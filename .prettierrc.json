{
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "proseWrap": "preserve",
  "overrides": [
    {
      "files": "*.feature",
      "options": {
        "embeddedLanguageFormatting": "off"
      }
    }
  ],
  "plugins": ["prettier-plugin-gherkin"]
}
