{
  "default": {
    "paths": ["tests/bdd/business-logic/**/*.feature"],
    "requireModule": ["ts-node/register/transpile-only"],
    "require": ["tests/bdd/**/*.ts"],
    "format": ["progress-bar", "html:test-results/reports/cucumber-report.html"],
    "timeout": 60000,
    "publishQuiet": true
  },
  "smoke": {
    "paths": ["tests/bdd/business-logic/**/*.feature"],
    "requireModule": ["ts-node/register/transpile-only"],
    "require": ["tests/bdd/**/*.ts"],
    "format": ["progress-bar", "html:test-results/reports/cucumber-report.html"],
    "tags": "@smoke",
    "timeout": 60000,
    "publishQuiet": true
  },
  "component": {
    "paths": ["tests/bdd/business-logic/**/*.feature"],
    "requireModule": ["ts-node/register/transpile-only"],
    "require": ["tests/bdd/**/*.ts"],
    "format": ["progress-bar", "html:test-results/reports/cucumber-report.html"],
    "tags": "@integration",
    "timeout": 60000,
    "publishQuiet": true
  }
}